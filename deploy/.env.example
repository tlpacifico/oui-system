# Copiar para /opt/oui-system/.env na VPS e preencher os valores reais.
# NUNCA commitar o .env com valores reais.

# PostgreSQL
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=oui_db;Username=oui_user;Password=ALTERAR

# Firebase
FIREBASE_PROJECT_ID=ALTERAR

# Email (MailKit / SMTP)
EMAIL_HOST=smtp.ALTERAR.com
EMAIL_PORT=587
EMAIL_USERNAME=ALTERAR
EMAIL_PASSWORD=ALTERAR
EMAIL_FROM=noreply@ALTERAR.com
